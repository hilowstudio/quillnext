# Quill & Compass — environment variables
# Copy to `.env` and fill in. Do NOT commit a populated `.env`.
# Key list verified against the codebase (process.env.* usage); placeholder values only.

# --- Database (PostgreSQL / Supabase) ---
# DATABASE_URL is the pooled/runtime connection; DIRECT_DATABASE_URL is the
# direct (non-pooled) connection used for migrations/seeds. Prisma resolves
# DIRECT_DATABASE_URL ?? DATABASE_URL (see prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# RLS is OFF by default in the app layer; leave false unless you know why.
RLS_ENABLED="false"
# Optional Prisma engine override; leave unset unless required.
# PRISMA_CLIENT_ENGINE_TYPE=""

# --- Auth (NextAuth v5 + Google OAuth) ---
# AUTH_SECRET / NEXTAUTH_SECRET: random 32+ byte secret (e.g. `openssl rand -base64 32`).
AUTH_SECRET=""
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI (Vercel AI SDK) ---
# Google Gemini is the primary provider.
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_API_KEY=""

# --- Supabase (client + service role) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Firebase Admin (server-side storage) ---
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Paste the private key with literal \n newlines, quoted.
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""

# --- Email (Resend) ---
RESEND_API_KEY=""
# From-address for child-safety alert emails.
SAFETY_ALERT_FROM=""

# --- Third-party content APIs ---
YOUTUBE_API_KEY=""
GOOGLE_BOOKS_API_KEY=""
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=""
JOSHUA_PROJECT_API_KEY=""
BIBLE_API_KEY=""

# --- Hi-Low ingest integration ---
HILOW_INGEST_URL=""
HILOW_INGEST_KEY=""

# Note: NODE_ENV and VERCEL / VERCEL_ENV / VERCEL_GIT_COMMIT_SHA are provided by
# the runtime/platform and should not be set here.
